# OCR Pipeline — Environment Variables
# Copy to .env and fill in your keys. Never commit .env to version control.
# .env is already in .gitignore.

# Google Gemini (free tier: https://aistudio.google.com)
GEMINI_API_KEY=

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Mathpix (free tier: 1000 pages/month at https://mathpix.com)
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Google Document AI (https://console.cloud.google.com)
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Gemini API key (alias — either this or GEMINI_API_KEY works)
# GOOGLE_API_KEY=

# Optional: Override default values
# OCR_PIPELINE_PROFILE=general
# OCR_PIPELINE_ENGINES=marker,tesseract
# OCR_PIPELINE_VLM_MODEL=gemini-2.5-flash
# OCR_PIPELINE_INCLUDE_METADATA_PER_PAGE=true
# OCR_PIPELINE_PDF_CONCURRENCY=2
